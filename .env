APP_ENV=dev
APP_SECRET=change_me_in_production
DEFAULT_URI=http://localhost:8080

# PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}?serverVersion=16&charset=utf8"

# RabbitMQ
RABBITMQ_USER=app
RABBITMQ_PASSWORD=change_me
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DSN="amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:${RABBITMQ_PORT}/%2f"

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# Nginx
NGINX_PORT=8080

# PHP
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=30
